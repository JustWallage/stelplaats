# Copy to .bootstrap.env (gitignored), fill in, then run scripts/bootstrap.sh.
# Where each value comes from is documented in docs/BOOTSTRAP.md.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random string gating the e2e auth path on deployed e2e workers.
# Generate with: openssl rand -hex 32
TEST_AUTH_TOKEN=
# The X in https://<worker>.X.workers.dev — find it under Workers & Pages →
# your subdomain, or via: wrangler whoami
WORKERS_DEV_SUBDOMAIN=
