{
  "name": "stelplaats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm migrate:local && vite",
    "dev:e2e": "pnpm migrate:local:e2e && CLOUDFLARE_ENV=e2e vite",
    "build": "vite build",
    "preview": "vite preview",
    "cf-typegen": "wrangler types",
    "migrate:gen": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:local:e2e": "wrangler d1 migrations apply DB --local --env e2e"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.100.0"
  }
}
