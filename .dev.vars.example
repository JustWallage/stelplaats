# Copy to .dev.vars (gitignored). Loaded by wrangler/vite-plugin for local dev.
DEV_USER_EMAIL=just@wallage.nl
TEST_AUTH_TOKEN=local-test-token

# Home Assistant (only needed to exercise the Lights controls locally).
# HASS_TOKEN: a long-lived access token from your HASS profile.
# HASS_ACCESS_*: the hass-api Access service token (terraform output).
HASS_TOKEN=replace-with-hass-long-lived-token
HASS_ACCESS_CLIENT_ID=replace-with-access-service-token-client-id
HASS_ACCESS_CLIENT_SECRET=replace-with-access-service-token-client-secret

# Telegram bot (optional). Without TELEGRAM_BOT_TOKEN the bot client is a no-op
# fake — the connect flow still works locally, but no message is actually sent.
# TELEGRAM_WEBHOOK_SECRET gates POST /telegram/webhook; set it to drive the bot
# webhook locally (any string).
# TELEGRAM_BOT_TOKEN=replace-with-botfather-token
# TELEGRAM_WEBHOOK_SECRET=local-webhook-secret

# Web Push / VAPID (optional). Generate a pair with
# `node scripts/generate-vapid.mjs`. With all three set, GET /api/push exposes
# the public key and the worker actually delivers notifications; without the
# private key the push sender is a no-op fake (the subscribe/test flow still
# works, nothing is delivered).
# VAPID_PUBLIC_KEY=replace-with-generated-public-key
# VAPID_PRIVATE_KEY=replace-with-generated-private-scalar
# VAPID_SUBJECT=mailto:you@example.com
